# ----- Google Sheets (source of truth) -----
# Full JSON of a Google service account with Viewer access to the Moose sheet.
# Share the sheet with client_email from this JSON. Paste the entire JSON on one line.
GOOGLE_SERVICE_ACCOUNT_JSON=

# The Moose sheet ID from its URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
MOOSE_SHEET_ID=
# The Planning tab's gid (numeric) — used to build deep links.
PLANNING_GID=

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by the sync job to upsert cache. Never ship to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ----- NextAuth / Google SSO -----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Cron -----
# Any long random string. Vercel cron sets `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=

# ----- Optional / V2 -----
# Confirm exact URL with Harry; pattern usually https://innovera.atlassian.net/browse/{KEY}
JIRA_BASE_URL=https://innovera.atlassian.net/browse
